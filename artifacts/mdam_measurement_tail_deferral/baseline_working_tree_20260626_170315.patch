-    t0 = time.perf_counter()
-    while n < target:
-        m = clifft.sample(prog, chunk, seed=s).measurements
-        tot += m.sum(axis=0); n += chunk; s += 1
-        if time.perf_counter() - t0 >= budget_s:
-            break
